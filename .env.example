# Copy to .env and fill in values

# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/orchestrator

# Auth
JWT_SECRET=generate-a-64-char-random-string-here
FERNET_KEY=generate-with-python-cryptography-fernet

# Railway API (for provisioning customer instances)
RAILWAY_API_TOKEN=your-railway-account-or-workspace-token
RAILWAY_WORKSPACE_ID=your-workspace-id

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform
PLATFORM_DOMAIN=https://your-app.railway.app
ADMIN_EMAIL=your-email@domain.com
